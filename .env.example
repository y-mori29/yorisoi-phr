# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Firestore は Application Default Credentials を使用
# ローカル開発時: gcloud auth application-default login

# LIFF
LIFF_CHANNEL_ID=your-line-channel-id

# Gemini API (AI入力補助：音声解析・お薬手帳スキャン・検査結果読み取り)
GEMINI_API_KEY=your-gemini-api-key

# サーバー
PORT=8080
ALLOW_ORIGIN=https://yorisoi.medi-canvas.com
DEMO_MODE=1
