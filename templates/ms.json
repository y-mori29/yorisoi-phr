{
  "id": "ms",
  "name": "多発性硬化症",
  "shortName": "MS",
  "description": "多発性硬化症（Multiple Sclerosis）の治療歴・薬・症状を管理",
  "color": "#8b5cf6",
  "icon": "🧠",

  "modules": [
    { "id": "timeline", "label": "治療タイムライン", "description": "治療経歴を時系列で管理", "icon": "📅", "page": "timeline.html", "enabled": true, "core": true },
    { "id": "medications", "label": "おくすり管理", "description": "処方薬と変更履歴", "icon": "💊", "page": "medications.html", "enabled": true, "core": true },
    { "id": "symptom-log", "label": "症状きろく", "description": "神経症状をかんたん記録", "icon": "📝", "page": "symptom-log.html", "enabled": true },
    { "id": "restroom", "label": "トイレさがし", "description": "近くのトイレをマップで表示", "icon": "🚾", "page": "restroom.html", "enabled": false },
    { "id": "emergency-card", "label": "緊急カード", "description": "救急時に見せる情報カード", "icon": "🆘", "page": "emergency-card.html", "enabled": true, "core": true },
    { "id": "lab-tracker", "label": "検査値きろく", "description": "血液検査の推移をグラフ表示", "icon": "🔬", "page": "lab-tracker.html", "enabled": true, "core": true },
    { "id": "summary", "label": "診察用サマリー", "description": "診察時に医師に見せる画面", "icon": "📋", "page": "summary.html", "enabled": true, "core": true, "fullWidth": true }
  ],

  "medicationMaster": "ms-medications.json",

  "symptomConfig": {
    "title": "症状きろく",
    "metrics": [
      { "id": "fatigue", "label": "疲労感", "type": "scale", "min": 0, "max": 5 },
      { "id": "walkingDistance", "label": "歩ける距離", "type": "scale", "min": 0, "max": 5, "labels": ["寝たきり", "数m", "屋内", "100m", "500m", "1km以上"] },
      { "id": "visionChange", "label": "視力変化あり", "type": "toggle", "dangerColor": true },
      { "id": "numbness", "label": "しびれ・感覚異常", "type": "toggle" },
      { "id": "bladderIssue", "label": "排尿トラブル", "type": "toggle" },
      { "id": "cognitiveIssue", "label": "集中困難", "type": "toggle" },
      { "id": "painScore", "label": "痛み", "type": "scale", "min": 0, "max": 5 }
    ],
    "summaryMetrics": [
      { "id": "fatigue", "label": "平均疲労", "aggregate": "avg" },
      { "id": "walkingDistance", "label": "平均歩行", "aggregate": "avg" },
      { "id": "visionChange", "label": "視力変化日数", "aggregate": "countTrue" },
      { "id": "bladderIssue", "label": "排尿トラブル日数", "aggregate": "countTrue" }
    ]
  },

  "labConfig": {
    "items": [
      { "id": "wbc", "label": "白血球数", "unit": "/μL", "normalRange": [3500, 9000] },
      { "id": "lymph", "label": "リンパ球数", "unit": "/μL", "normalRange": [1000, 4000], "warnLow": 500 },
      { "id": "jcv", "label": "JCV抗体指数", "unit": "index", "normalRange": [0, 0.9], "warnHigh": 1.5 },
      { "id": "igg", "label": "IgG", "unit": "mg/dL", "normalRange": [870, 1700] },
      { "id": "alt", "label": "ALT", "unit": "U/L", "normalRange": [5, 40], "warnHigh": 80 },
      { "id": "ast", "label": "AST", "unit": "U/L", "normalRange": [10, 40], "warnHigh": 80 },
      { "id": "cre", "label": "クレアチニン", "unit": "mg/dL", "normalRange": [0.5, 1.0], "warnHigh": 1.3 },
      { "id": "vitd", "label": "ビタミンD", "unit": "ng/mL", "normalRange": [30, 100], "warnLow": 20 }
    ]
  },

  "emergencyConfig": {
    "title": "緊急情報カード",
    "subtitle": "多発性硬化症",
    "fields": [
      { "id": "msType", "label": "病型", "placeholder": "例: 再発寛解型(RRMS)" },
      { "id": "edss", "label": "EDSS", "placeholder": "例: 2.5" }
    ],
    "warnings": [
      "免疫調節薬（DMT）使用中",
      "ナタリズマブ使用時は進行性多巣性白質脳症(PML)リスク",
      "ステロイドパルス療法の既往あり",
      "発熱時は再発症状との鑑別が必要",
      "MRIコントラスト造影剤使用時は主治医確認"
    ]
  },

  "timelineCategories": [
    { "id": "diagnosis", "label": "診断", "color": "#dbeafe" },
    { "id": "relapse", "label": "再発", "color": "#fca5a5" },
    { "id": "medication_change", "label": "薬変更", "color": "#d1fae5" },
    { "id": "exam", "label": "検査", "color": "#e9d5ff" },
    { "id": "mri", "label": "MRI", "color": "#c7d2fe" },
    { "id": "hospitalization", "label": "入院", "color": "#fde68a" },
    { "id": "rehabilitation", "label": "リハビリ", "color": "#fed7aa" },
    { "id": "other", "label": "その他", "color": "#e5e5e5" }
  ]
}
