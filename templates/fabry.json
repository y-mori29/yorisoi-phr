{
  "id": "fabry",
  "name": "ファブリー病",
  "shortName": "Fabry",
  "description": "ファブリー病（Fabry disease）の治療歴・薬・症状を管理",
  "color": "#db2777",
  "icon": "🧬",

  "modules": [
    { "id": "timeline", "label": "治療タイムライン", "description": "治療経歴を時系列で管理", "icon": "📅", "page": "timeline.html", "enabled": true, "core": true },
    { "id": "medications", "label": "おくすり管理", "description": "処方薬と変更履歴", "icon": "💊", "page": "medications.html", "enabled": true, "core": true },
    { "id": "symptom-log", "label": "症状きろく", "description": "全身症状をかんたん記録", "icon": "📝", "page": "symptom-log.html", "enabled": true },
    { "id": "restroom", "label": "トイレさがし", "description": "近くのトイレをマップで表示", "icon": "🚾", "page": "restroom.html", "enabled": false },
    { "id": "emergency-card", "label": "緊急カード", "description": "救急時に見せる情報カード", "icon": "🆘", "page": "emergency-card.html", "enabled": true, "core": true },
    { "id": "lab-tracker", "label": "検査値きろく", "description": "血液検査の推移をグラフ表示", "icon": "🔬", "page": "lab-tracker.html", "enabled": true, "core": true },
    { "id": "summary", "label": "診察用サマリー", "description": "診察時に医師に見せる画面", "icon": "📋", "page": "summary.html", "enabled": true, "core": true, "fullWidth": true }
  ],

  "medicationMaster": "fabry-medications.json",

  "symptomConfig": {
    "title": "症状きろく",
    "metrics": [
      { "id": "extremityPain", "label": "四肢の痛み・しびれ", "type": "scale", "min": 0, "max": 5, "description": "アクロパレステジア" },
      { "id": "gastrointestinal", "label": "消化器症状（腹痛・下痢）", "type": "toggle" },
      { "id": "fatigue", "label": "疲労感", "type": "scale", "min": 0, "max": 5 },
      { "id": "sweatIssue", "label": "発汗異常（無汗・低汗）", "type": "toggle" },
      { "id": "tinnitus", "label": "耳鳴り・難聴", "type": "toggle" },
      { "id": "dizziness", "label": "めまい", "type": "toggle" },
      { "id": "ertSideEffect", "label": "ERT投与後の副反応", "type": "toggle", "dangerColor": true }
    ],
    "summaryMetrics": [
      { "id": "extremityPain", "label": "平均疼痛", "aggregate": "avg" },
      { "id": "fatigue", "label": "平均疲労", "aggregate": "avg" },
      { "id": "gastrointestinal", "label": "消化器症状日数", "aggregate": "countTrue" },
      { "id": "ertSideEffect", "label": "ERT副反応日数", "aggregate": "countTrue" }
    ]
  },

  "labConfig": {
    "items": [
      { "id": "lysogb3", "label": "Lyso-Gb3", "unit": "ng/mL", "normalRange": [0, 1.8], "warnHigh": 5 },
      { "id": "galA", "label": "α-ガラクトシダーゼA活性", "unit": "nmol/h/mg", "normalRange": [25, 100] },
      { "id": "egfr", "label": "eGFR", "unit": "mL/min", "normalRange": [60, 150], "warnLow": 45 },
      { "id": "uprot", "label": "尿蛋白", "unit": "g/gCr", "normalRange": [0, 0.15], "warnHigh": 0.5 },
      { "id": "cre", "label": "クレアチニン", "unit": "mg/dL", "normalRange": [0.5, 1.0], "warnHigh": 1.3 },
      { "id": "bnp", "label": "BNP", "unit": "pg/mL", "normalRange": [0, 18.4], "warnHigh": 100 },
      { "id": "lvef", "label": "心エコー LVEF", "unit": "%", "normalRange": [55, 80], "warnLow": 40 },
      { "id": "troponin", "label": "高感度トロポニン", "unit": "ng/L", "normalRange": [0, 14], "warnHigh": 50 }
    ]
  },

  "emergencyConfig": {
    "title": "緊急情報カード",
    "subtitle": "ファブリー病",
    "fields": [
      { "id": "geneType", "label": "遺伝子型", "placeholder": "例: GLA遺伝子変異" },
      { "id": "treatment", "label": "治療内容", "placeholder": "例: 2週ごとERT" }
    ],
    "warnings": [
      "隔週の酵素補充療法（ERT）実施中",
      "心肥大・腎機能低下・脳血管障害のリスクあり",
      "ERT副反応（発熱・悪寒・発疹）の既往あり",
      "疼痛発作時はカルバマゼピン使用歴を確認",
      "手術・麻酔時は心機能・腎機能の評価が必要"
    ]
  },

  "timelineCategories": [
