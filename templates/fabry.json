  "labConfig": {
    "items": [
      { "id": "lysogb3", "label": "Lyso-Gb3（血漿）", "unit": "ng/mL", "normalRange": [0, 2.0], "warnHigh": 2.7, "note": "LC-MS/MS測定。正常<2.0、2.0以上で疾患疑い、>2.7で臓器障害リスク高（新潟大学/武田基準）" },
      { "id": "galA", "label": "α-ガラクトシダーゼA活性", "unit": "nmol/h/mg", "normalRange": [25, 100], "warnLow": 4, "note": "男性で<4.0 nmol/h/mLは診断上の重要指標" },
      { "id": "mulberry", "label": "尿中マルベリー小体", "unit": "/HPF", "normalRange": [0, 0], "note": "尿蛋白より早期に出現。ERT効果判定に有用（感度>82%・特異度>94%）" },
      { "id": "uGb3", "label": "尿中Gb3", "unit": "μg/mmolCr", "normalRange": [0, 50], "note": "尿中に排泄される糖脂質" },
      { "id": "egfr", "label": "eGFR", "unit": "mL/min", "normalRange": [60, 150], "warnLow": 45 },
      { "id": "uprot", "label": "尿蛋白（UPCR）", "unit": "g/gCr", "normalRange": [0, 0.15], "warnHigh": 0.5 },
      { "id": "cre", "label": "クレアチニン", "unit": "mg/dL", "normalRange": [0.5, 1.0], "warnHigh": 1.3 },
      { "id": "bnp", "label": "BNP", "unit": "pg/mL", "normalRange": [0, 18.4], "warnHigh": 100 },
      { "id": "lvef", "label": "心エコー LVEF", "unit": "%", "normalRange": [55, 80], "warnLow": 40 },
      { "id": "troponin", "label": "高感度トロポニン", "unit": "ng/L", "normalRange": [0, 14], "warnHigh": 50 },
      { "id": "ada_igg", "label": "抗薬物抗体（IgG）", "unit": "結果", "note": "ERTの継続判断に影響。リプレガルでIgG陽性率39%" }
    ]
  },

