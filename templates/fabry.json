      { "id": "infusionReaction", "label": "輸注関連反応（IRR）", "type": "toggle", "dangerColor": true, "description": "ERT投与中〜直後の発熱・悪寒・発疹" },
      { "id": "ertSideEffect", "label": "ERT投与後の体調不良", "type": "toggle", "description": "投与翌日以降の遅延反応" }
