  "symptomConfig": {
    "title": "症状きろく",
    "metrics": [
      {
        "id": "bowelCount",
        "label": "排便回数",
        "type": "counter",
        "min": 0,
        "max": 30,
        "default": 0,
        "unit": "回"
      },
      {
        "id": "bristolScale",
        "label": "便の状態（ブリストルスケール）",
        "type": "scale",
        "min": 1,
        "max": 7,
        "labels": ["硬", "塊", "ひび", "普通", "柔", "泥", "水"],
        "description": "1=硬い ← → 7=水様"
      },
      {
        "id": "bleeding",
        "label": "血便あり",
        "type": "toggle",
        "dangerColor": true
      },
      {
        "id": "painScore",
        "label": "おなかの痛み",
        "type": "scale",
        "min": 0,
        "max": 5,
        "description": "0=なし ← → 5=とても痛い"
      }
    ],
    "summaryMetrics": [
      { "id": "bowelCount", "label": "平均回数/日", "aggregate": "avg" },
      { "id": "bleeding", "label": "血便日数", "aggregate": "countTrue" },
      { "id": "painScore", "label": "平均痛み", "aggregate": "avg" }
    ]
  },

