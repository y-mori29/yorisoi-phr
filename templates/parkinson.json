          { "name": "全国パーキンソン病友の会 各都道府県支部", "url": "https://jpda.jp/%E5%90%84%E9%83%BD%E9%81%93%E5%BA%9C%E7%9C%8C%E6%94%AF%E9%83%A8%E3%81%AE%E6%83%85%E5%A0%B1/", "note": "お住まいの地域の支部・定例会・連絡先を検索。はじめの一歩はここから。" }
        ]
      },
      {
        "heading": "公的支援・医療費助成",
        "icon": "account_balance",
        "items": [
          { "name": "難病情報センター：パーキンソン病（指定難病6）", "url": "https://www.nanbyou.or.jp/entry/314", "note": "疾患解説・ヤール重症度・医療費助成の要件・申請方法をまとめた公式ページ。" },
          { "name": "日本難病・疾病団体協議会（JPA）", "url": "https://nanbyo.jp/", "note": "難病相談支援センター・就労支援・介護保険との併用など制度相談の入口。" }
        ]
      },
      {
        "heading": "医療情報・診療拠点",
        "icon": "local_hospital",
        "items": [
          { "name": "日本神経学会：パーキンソン病診療ガイドライン2018", "url": "https://www.neurology-jp.org/guidelinem/parkinson_2018.html", "note": "専門医向けの公式ガイドライン。診断・薬物・デバイス補助療法・リハビリの標準指針。" },
          { "name": "日本神経学会 ガイドライン一覧", "url": "https://www.neurology-jp.org/guidelinem/index.html", "note": "神経疾患全般の診療ガイドライン索引。改訂版が出たらここから辿れる。" }
        ]
      }
