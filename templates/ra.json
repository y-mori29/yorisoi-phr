{
  "id": "ra",
  "name": "関節リウマチ",
  "shortName": "RA",
  "description": "関節リウマチ（Rheumatoid Arthritis）の治療歴・薬・症状を管理",
  "color": "#059669",
  "icon": "🦴",

  "modules": [
    { "id": "timeline", "label": "治療タイムライン", "description": "治療経歴を時系列で管理", "icon": "📅", "page": "timeline.html", "enabled": true, "core": true },
    { "id": "medications", "label": "おくすり管理", "description": "処方薬と変更履歴", "icon": "💊", "page": "medications.html", "enabled": true, "core": true },
    { "id": "symptom-log", "label": "症状きろく", "description": "関節の状態を毎日記録", "icon": "📝", "page": "symptom-log.html", "enabled": true },
    { "id": "restroom", "label": "トイレさがし", "description": "近くのトイレをマップで表示", "icon": "🚾", "page": "restroom.html", "enabled": false },
    { "id": "emergency-card", "label": "緊急カード", "description": "救急時に見せる情報カード", "icon": "🆘", "page": "emergency-card.html", "enabled": true, "core": true },
    { "id": "lab-tracker", "label": "検査値きろく", "description": "血液検査の推移をグラフ表示", "icon": "🔬", "page": "lab-tracker.html", "enabled": true, "core": true },
    { "id": "summary", "label": "診察用サマリー", "description": "診察時に医師に見せる画面", "icon": "📋", "page": "summary.html", "enabled": true, "core": true, "fullWidth": true }
  ],

  "medicationMaster": "ra-medications.json",

  "symptomConfig": {
    "title": "症状きろく",
    "metrics": [
      { "id": "morningStiffness", "label": "朝のこわばり", "type": "counter", "min": 0, "max": 240, "default": 0, "unit": "分" },
      { "id": "jointPain", "label": "関節の痛み", "type": "scale", "min": 0, "max": 5 },
      { "id": "swollenJoints", "label": "腫れている関節数", "type": "counter", "min": 0, "max": 28, "default": 0, "unit": "箇所" },
      { "id": "tenderJoints", "label": "圧痛関節数", "type": "counter", "min": 0, "max": 28, "default": 0, "unit": "箇所" },
      { "id": "fatigue", "label": "疲労感", "type": "scale", "min": 0, "max": 5 },
      { "id": "funcLimitation", "label": "日常生活の支障", "type": "scale", "min": 0, "max": 5, "description": "0=なし ← → 5=寝たきり" }
    ],
    "summaryMetrics": [
      { "id": "morningStiffness", "label": "平均こわばり(分)", "aggregate": "avg" },
      { "id": "jointPain", "label": "平均関節痛", "aggregate": "avg" },
      { "id": "swollenJoints", "label": "平均腫脹関節数", "aggregate": "avg" },
      { "id": "fatigue", "label": "平均疲労", "aggregate": "avg" }
    ]
  },

  "labConfig": {
    "items": [
      { "id": "crp", "label": "CRP", "unit": "mg/dL", "normalRange": [0, 0.3], "warnHigh": 1.0 },
      { "id": "esr", "label": "赤沈（ESR）", "unit": "mm/h", "normalRange": [0, 15], "warnHigh": 30 },
      { "id": "rf", "label": "リウマトイド因子（RF）", "unit": "IU/mL", "normalRange": [0, 15], "warnHigh": 30 },
      { "id": "accp", "label": "抗CCP抗体", "unit": "U/mL", "normalRange": [0, 4.5], "warnHigh": 10 },
      { "id": "mmp3", "label": "MMP-3", "unit": "ng/mL", "normalRange": [36.9, 121] },
      { "id": "hb", "label": "Hb（ヘモグロビン）", "unit": "g/dL", "normalRange": [12, 17], "warnLow": 10 },
      { "id": "plt", "label": "血小板数", "unit": "万/μL", "normalRange": [15, 35] },
      { "id": "alt", "label": "ALT（GPT）", "unit": "U/L", "normalRange": [5, 40], "warnHigh": 80 },
      { "id": "cre", "label": "クレアチニン", "unit": "mg/dL", "normalRange": [0.5, 1.0], "warnHigh": 1.3 },
      { "id": "egfr", "label": "eGFR", "unit": "mL/min", "normalRange": [60, 150], "warnLow": 45 }
    ]
  },

  "emergencyConfig": {
    "title": "緊急情報カード",
    "subtitle": "関節リウマチ",
    "fields": [
      { "id": "stage", "label": "進行度", "placeholder": "例: Stage II" },
      { "id": "activity", "label": "疾患活動性", "placeholder": "例: 中等度" }
    ],
    "warnings": [
      "生物学的製剤/JAK阻害薬使用中は感染症・結核再燃のリスク",
      "メトトレキサート服用中は手術前に休薬相談が必要",
      "ステロイド服用中の急な中断は副腎不全のリスク",
      "免疫抑制状態のため発熱・感染兆候は早期受診"
    ]
  },

  "timelineCategories": [
    { "id": "diagnosis", "label": "診断", "color": "#dbeafe" },
    { "id": "medication_change", "label": "薬変更", "color": "#d1fae5" },
    { "id": "flare", "label": "再燃", "color": "#fca5a5" },
    { "id": "exam", "label": "検査", "color": "#e9d5ff" },
    { "id": "surgery", "label": "手術", "color": "#fecaca" },
    { "id": "rehabilitation", "label": "リハビリ", "color": "#fde68a" },
    { "id": "other", "label": "その他", "color": "#e5e5e5" }
  ]
}
