{
  "id": "pah",
  "name": "肺動脈性肺高血圧症",
  "shortName": "PAH",
  "description": "肺動脈性肺高血圧症（Pulmonary Arterial Hypertension）の治療歴・薬・症状を管理",
  "color": "#0284c7",
  "icon": "🫁",

  "modules": [
    { "id": "timeline", "label": "治療タイムライン", "description": "治療経歴を時系列で管理", "icon": "📅", "page": "timeline.html", "enabled": true, "core": true },
    { "id": "medications", "label": "おくすり管理", "description": "処方薬と変更履歴", "icon": "💊", "page": "medications.html", "enabled": true, "core": true },
    { "id": "symptom-log", "label": "症状きろく", "description": "息切れ・SpO2を記録", "icon": "📝", "page": "symptom-log.html", "enabled": true },
    { "id": "restroom", "label": "トイレさがし", "description": "近くのトイレをマップで表示", "icon": "🚾", "page": "restroom.html", "enabled": false },
    { "id": "emergency-card", "label": "緊急カード", "description": "救急時に見せる情報カード", "icon": "🆘", "page": "emergency-card.html", "enabled": true, "core": true },
    { "id": "lab-tracker", "label": "検査値きろく", "description": "血液検査の推移をグラフ表示", "icon": "🔬", "page": "lab-tracker.html", "enabled": true, "core": true },
    { "id": "summary", "label": "診察用サマリー", "description": "診察時に医師に見せる画面", "icon": "📋", "page": "summary.html", "enabled": true, "core": true, "fullWidth": true }
  ],

  "medicationMaster": "pah-medications.json",

  "symptomConfig": {
    "title": "症状きろく",
    "metrics": [
      { "id": "dyspnea", "label": "息切れ（NYHA）", "type": "scale", "min": 0, "max": 4, "description": "0=なし ← → 4=安静時" },
      { "id": "spo2", "label": "SpO2", "type": "counter", "min": 70, "max": 100, "default": 95, "unit": "%" },
      { "id": "walkingCapacity", "label": "歩ける距離", "type": "scale", "min": 0, "max": 5, "labels": ["寝たきり", "屋内のみ", "100m", "500m", "1km", "制限なし"] },
      { "id": "edema", "label": "むくみ", "type": "scale", "min": 0, "max": 3, "labels": ["なし", "軽度", "中等度", "高度"] },
      { "id": "chestPain", "label": "胸痛", "type": "toggle" },
      { "id": "syncope", "label": "失神・前兆", "type": "toggle", "dangerColor": true },
      { "id": "palpitation", "label": "動悸", "type": "toggle" },
      { "id": "fatigue", "label": "疲労感", "type": "scale", "min": 0, "max": 5 }
    ],
    "summaryMetrics": [
      { "id": "dyspnea", "label": "平均息切れ", "aggregate": "avg" },
      { "id": "spo2", "label": "平均SpO2", "aggregate": "avg" },
      { "id": "walkingCapacity", "label": "平均歩行", "aggregate": "avg" },
      { "id": "edema", "label": "平均むくみ", "aggregate": "avg" },
      { "id": "syncope", "label": "失神日数", "aggregate": "countTrue" }
    ]
  },

  "labConfig": {
    "items": [
      { "id": "bnp", "label": "BNP", "unit": "pg/mL", "normalRange": [0, 18.4], "warnHigh": 100 },
      { "id": "ntprobnp", "label": "NT-proBNP", "unit": "pg/mL", "normalRange": [0, 125], "warnHigh": 300 },
      { "id": "egfr", "label": "eGFR", "unit": "mL/min", "normalRange": [60, 150], "warnLow": 45 },
      { "id": "cre", "label": "クレアチニン", "unit": "mg/dL", "normalRange": [0.5, 1.0], "warnHigh": 1.3 },
      { "id": "ast", "label": "AST", "unit": "U/L", "normalRange": [10, 40], "warnHigh": 80 },
      { "id": "alt", "label": "ALT", "unit": "U/L", "normalRange": [5, 40], "warnHigh": 80 },
      { "id": "ua", "label": "尿酸", "unit": "mg/dL", "normalRange": [3.5, 7.0], "warnHigh": 9 },
      { "id": "na", "label": "Na", "unit": "mEq/L", "normalRange": [135, 145] },
      { "id": "k", "label": "K（カリウム）", "unit": "mEq/L", "normalRange": [3.5, 5.0] },
      { "id": "hb", "label": "Hb", "unit": "g/dL", "normalRange": [12, 17] },
      { "id": "plt", "label": "血小板", "unit": "万/μL", "normalRange": [15, 35] }
    ]
  },

  "emergencyConfig": {
    "title": "緊急情報カード",
    "subtitle": "肺動脈性肺高血圧症（PAH）",
    "fields": [
      { "id": "whoFc", "label": "WHO機能分類", "placeholder": "例: II" },
      { "id": "therapy", "label": "現在の治療", "placeholder": "例: 3剤併用" }
    ],
    "warnings": [
      "⚠️ プロスタサイクリン持続静注中の場合、ポンプ停止は生命の危険",
      "失神・急激な呼吸困難は緊急受診",
      "塩分・水分制限中",
      "抗凝固薬（ワルファリン）服用の有無確認",
      "妊娠は禁忌レベルのリスク",
      "高所・飛行機搭乗は主治医相談が必要"
    ]
  },

  "timelineCategories": [
    { "id": "diagnosis", "label": "診断", "color": "#dbeafe" },
    { "id": "rhc", "label": "右心カテーテル", "color": "#c7d2fe" },
    { "id": "medication_change", "label": "薬変更", "color": "#d1fae5" },
    { "id": "hospitalization", "label": "入院", "color": "#fde68a" },
    { "id": "exam", "label": "検査", "color": "#e9d5ff" },
    { "id": "complication", "label": "合併症", "color": "#fca5a5" },
    { "id": "other", "label": "その他", "color": "#e5e5e5" }
  ]
}
